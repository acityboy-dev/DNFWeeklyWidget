<Window x:Class="DNFWeeklyWidget.SettingsWindow"
		xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
		Title="설정"
		Width="860"
		Height="740"
		MinWidth="860"
		MinHeight="740"
		WindowStartupLocation="CenterOwner"
		WindowStyle="None"
		ShowInTaskbar="False"
		AllowsTransparency="False"
		Background="Transparent"
		ResizeMode="NoResize"
		MouseLeftButtonDown="Window_MouseLeftButtonDown">

	<shell:WindowChrome.WindowChrome>
		<shell:WindowChrome CaptionHeight="0"
							GlassFrameThickness="0"
							ResizeBorderThickness="0"
							UseAeroCaptionButtons="False"/>
	</shell:WindowChrome.WindowChrome>

	<Window.Resources>
		<Style x:Key="SettingsTabItemStyle" TargetType="TabItem">
			<Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
			<Setter Property="FontSize" Value="13"/>
			<Setter Property="FontWeight" Value="SemiBold"/>
			<Setter Property="HorizontalContentAlignment" Value="Left"/>
			<Setter Property="FocusVisualStyle" Value="{x:Null}"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="TabItem">
						<Border x:Name="TabChrome"
								Background="Transparent"
								CornerRadius="8"
								Padding="12 10"
								Margin="0 0 0 4">
							<ContentPresenter ContentSource="Header"
											  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
											  VerticalAlignment="Center"/>
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter TargetName="TabChrome" Property="Background" Value="{DynamicResource ButtonHoverBackgroundBrush}"/>
							</Trigger>
							<Trigger Property="IsSelected" Value="True">
								<Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
								<Setter TargetName="TabChrome" Property="Background" Value="{DynamicResource ButtonPressedBackgroundBrush}"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<Style x:Key="SettingsTabControlStyle" TargetType="TabControl">
			<Setter Property="TabStripPlacement" Value="Left"/>
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="TabControl">
						<Grid>
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="116"/>
								<ColumnDefinition Width="18"/>
								<ColumnDefinition Width="*"/>
							</Grid.ColumnDefinitions>
							<Border Background="{DynamicResource ButtonBackgroundBrush}"
									CornerRadius="8"
									Padding="6">
								<TabPanel IsItemsHost="True"/>
							</Border>
							<ContentPresenter Grid.Column="2"
											  ContentSource="SelectedContent"/>
						</Grid>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>
	</Window.Resources>

	<Border Background="Transparent" Padding="22">
		<Grid>
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="*"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
			</Grid.RowDefinitions>

			<Grid Grid.Row="0" Height="36" Margin="0 0 0 18">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="36"/>
				</Grid.ColumnDefinitions>

				<TextBlock Text="설정"
						   Foreground="{DynamicResource PrimaryTextBrush}"
						   FontSize="22"
						   FontWeight="Bold"
						   VerticalAlignment="Center"/>

				<Button Grid.Column="1"
						Width="36"
						Height="34"
						Padding="0"
						HorizontalAlignment="Right"
						VerticalAlignment="Top"
						Click="Cancel_Click">
					<Path Data="M 4 4 L 12 12 M 12 4 L 4 12"
						  Stroke="{DynamicResource PrimaryTextBrush}"
						  StrokeThickness="1"
						  StrokeStartLineCap="Round"
						  StrokeEndLineCap="Round"
						  Stretch="Uniform"
						  Width="14"
						  Height="14"/>
				</Button>
			</Grid>

			<Grid Grid.Row="1">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="480"/>
					<ColumnDefinition Width="24"/>
					<ColumnDefinition Width="*"/>
				</Grid.ColumnDefinitions>

				<TabControl Grid.Column="0"
							Style="{StaticResource SettingsTabControlStyle}"
							ItemContainerStyle="{StaticResource SettingsTabItemStyle}"
							SelectedIndex="0">
					<TabItem Header="일반">
						<StackPanel>
							<TextBlock Text="개인 API Key"
									   ToolTip="Neople Developers에서 발급받은 API Key를 입력하세요."
									   Foreground="{DynamicResource SecondaryTextBrush}"
									   FontSize="12"
									   FontWeight="SemiBold"
									   Margin="0 0 0 7"/>
							<TextBox x:Name="ApiKeyBox" Height="34" FontSize="15" Margin="0 0 0 22"/>

							<TextBlock Text="갱신 및 데이터"
									   Foreground="{DynamicResource SecondaryTextBrush}"
									   FontSize="12"
									   FontWeight="SemiBold"
									   Margin="0 0 0 10"/>
							<StackPanel>
								<CheckBox x:Name="AutoRefreshOnStartupBox"
										  Content="시작 시 자동 갱신"
										  Margin="0 0 0 12"/>
								<Grid Margin="22 0 0 14">
									<Grid.ColumnDefinitions>
										<ColumnDefinition Width="Auto"/>
										<ColumnDefinition Width="10"/>
										<ColumnDefinition Width="64"/>
										<ColumnDefinition Width="Auto"/>
									</Grid.ColumnDefinitions>
									<TextBlock Text="자동갱신 주기"
											   Foreground="{DynamicResource SecondaryTextBrush}"
											   FontSize="12"
											   VerticalAlignment="Center"/>
									<TextBox x:Name="AutoRefreshIntervalBox"
											 Grid.Column="2"
											 Height="30"
											 FontSize="13"
											 TextChanged="AutoRefreshIntervalBox_TextChanged"/>
									<TextBlock Grid.Column="3"
											   Text="분"
											   Foreground="{DynamicResource SecondaryTextBrush}"
											   FontSize="12"
											   VerticalAlignment="Center"
											   Margin="6 0 0 0"/>
								</Grid>
								<CheckBox x:Name="ShowInTaskbarBox" Content="작업 표시줄에 표시" Margin="0 0 0 12"/>
								<CheckBox x:Name="RunAtWindowsStartupBox" Content="Windows 시작 시 자동 실행" Margin="0 0 0 12"/>
								<CheckBox x:Name="EnableUserDataCacheBox" Content="사용자 데이터 저장" Margin="0 0 0 7"/>
								<TextBlock Text="끄면 앱 사용자설정, 카드 배열, 캐릭터 리스트가 저장되지 않습니다."
										   Foreground="{DynamicResource BlockedTextBrush}"
										   FontSize="11"
										   TextWrapping="Wrap"
										   Margin="22 0 0 0"/>
							</StackPanel>
						</StackPanel>
					</TabItem>

					<TabItem Header="화면">
						<StackPanel>
							<TextBlock Text="테마"
									   Foreground="{DynamicResource SecondaryTextBrush}"
									   FontSize="12"
									   FontWeight="SemiBold"
									   Margin="0 0 0 7"/>
							<ComboBox x:Name="ThemeModeBox"
									  Height="34"
									  FontSize="15"
									  DisplayMemberPath="Label"
									  SelectedValuePath="Value"
									  Margin="0 0 0 10"/>
							<CheckBox x:Name="LowPerformanceModeBox"
									  Content="저성능 모드"
									  Margin="0 0 0 22"
									  Checked="LowPerformanceModeBox_Changed"
									  Unchecked="LowPerformanceModeBox_Changed"/>

							<TextBlock Text="카드 표시"
									   Foreground="{DynamicResource SecondaryTextBrush}"
									   FontSize="12"
									   FontWeight="SemiBold"
									   Margin="0 0 0 10"/>
							<StackPanel>
								<TextBlock Text="캐릭터 이미지"
										   Foreground="{DynamicResource TertiaryTextBrush}"
										   FontSize="12"
										   Margin="0 0 0 7"/>
								<ComboBox x:Name="CharacterImageModeBox"
										  Height="34"
										  FontSize="15"
										  DisplayMemberPath="Label"
										  SelectedValuePath="Value"
										  Margin="0 0 0 18"/>
								<TextBlock Text="카드/줄"
										   Foreground="{DynamicResource TertiaryTextBrush}"
										   FontSize="12"
										   Margin="0 0 0 7"/>
								<Grid>
									<Grid.ColumnDefinitions>
										<ColumnDefinition Width="56"/>
										<ColumnDefinition Width="12"/>
										<ColumnDefinition Width="*"/>
									</Grid.ColumnDefinitions>
									<TextBox x:Name="ColumnsBox"
											 Height="34"
											 FontSize="15"
											 TextChanged="ColumnsBox_TextChanged"/>
									<Slider x:Name="ColumnsSlider"
											Grid.Column="2"
											Minimum="1"
											Maximum="10"
											TickFrequency="1"
											IsSnapToTickEnabled="True"
											VerticalAlignment="Center"
											ValueChanged="ColumnsSlider_ValueChanged"/>
								</Grid>
							</StackPanel>
						</StackPanel>
					</TabItem>

					<TabItem Header="주간 콘텐츠">
						<StackPanel>
							<TextBlock Text="주간 획득 정보"
									   Foreground="{DynamicResource SecondaryTextBrush}"
									   FontSize="12"
									   FontWeight="SemiBold"
									   Margin="0 0 0 10"/>
							<UniformGrid Columns="2" Margin="0 0 0 24">
								<CheckBox x:Name="WeeklyEquipmentLootBox" Content="중천장비" Margin="0 0 10 10"/>
								<CheckBox x:Name="WeeklyOathLootBox" Content="서약" Margin="0 0 0 10"/>
								<CheckBox x:Name="WeeklyCrystalLootBox" Content="결정"/>
							</UniformGrid>

							<TextBlock Text="표시할 주간 콘텐츠"
									   Foreground="{DynamicResource SecondaryTextBrush}"
									   FontSize="12"
									   FontWeight="SemiBold"
									   Margin="0 0 0 12"/>
							<TextBlock Text="레기온"
									   Foreground="{DynamicResource TertiaryTextBrush}"
									   FontSize="12"
									   FontWeight="SemiBold"
									   Margin="0 0 0 8"/>
							<UniformGrid Columns="2" Margin="0 0 0 20">
								<CheckBox x:Name="VenusBox" Content="베누스" Margin="0 0 10 0"/>
								<CheckBox x:Name="ApocalypseBox" Content="아포칼립스"/>
							</UniformGrid>

							<TextBlock Text="레이드"
									   Foreground="{DynamicResource TertiaryTextBrush}"
									   FontSize="12"
									   FontWeight="SemiBold"
									   Margin="0 0 0 8"/>
							<UniformGrid Columns="2">
								<CheckBox x:Name="BakalRaidBox" Content="바칼" Margin="0 0 10 10"/>
								<CheckBox x:Name="HardMistRaidBox" Content="하드 안개신" Margin="0 0 0 10"/>
								<CheckBox x:Name="NormalNabelRaidBox" Content="일반 나벨" Margin="0 0 10 10"/>
								<CheckBox x:Name="HardNabelRaidBox" Content="하드 나벨" Margin="0 0 0 10"/>
								<CheckBox x:Name="TwilightOfInaeBox" Content="이내 황혼전" Margin="0 0 10 10"/>
								<CheckBox x:Name="DiregieRaidBox" Content="디레지에" Margin="0 0 0 10"/>
							</UniformGrid>
						</StackPanel>
					</TabItem>
				</TabControl>

				<Border Grid.Column="2"
						Background="{DynamicResource ButtonBackgroundBrush}"
						CornerRadius="8"
						Padding="14">
					<ScrollViewer VerticalScrollBarVisibility="Auto"
								  HorizontalScrollBarVisibility="Disabled"
								  Padding="0 0 4 0">
						<StackPanel>
							<TextBlock Text="도움말"
									   Foreground="{DynamicResource PrimaryTextBrush}"
									   FontSize="15"
									   FontWeight="SemiBold"
									   Margin="0 0 0 12"/>
							<TextBlock Foreground="{DynamicResource TertiaryTextBrush}"
									   FontSize="12"
									   LineHeight="19"
									   TextWrapping="Wrap">
								<Run Text="카드를 드래그하면 순서를 바꿀 수 있습니다."/>
								<LineBreak/><LineBreak/>
								<Run Text="캐릭터명 입력 후 Enter 또는 추가 버튼으로 추가합니다. 삭제는 카드의 × 버튼을 누르거나, 드래그해서 아래쪽으로 드롭하면 됩니다."/>
								<LineBreak/><LineBreak/>
								<Run Text="설정값, 캐릭터 카드 목록 및 순서는 PC에 저장됩니다."/>
								<LineBreak/>
								<Run Text="사용자 데이터 저장을 끄면 현재 실행 중 변경사항만 적용되고 앱 종료 후 유지되지 않습니다."/>
								<LineBreak/><LineBreak/>
								<Run Text="이내 황혼전은 8캐릭 제한을 반영합니다. 나벨은 일반/하드 통합으로 판단하며 하드 나벨은 4캐릭 제한을 반영합니다."/>
								<LineBreak/><LineBreak/>
								<Run Text="명성이 부족한 콘텐츠는 카드에 진행불가로 표시됩니다."/>
							</TextBlock>
						</StackPanel>
					</ScrollViewer>
				</Border>
			</Grid>

			<StackPanel Grid.Row="2" HorizontalAlignment="Center" Margin="0 18 0 14">
				<TextBlock Text="Made by @ansancityboy"
						   Foreground="{DynamicResource SecondaryTextBrush}"
						   Opacity="0.55"
						   FontSize="11"
						   HorizontalAlignment="Center"
						   Margin="0 0 0 5"/>

				<Border Padding="3 1"
						CornerRadius="6"
						Background="Transparent"
						HorizontalAlignment="Center">
					<Border.Style>
						<Style TargetType="Border">
							<Setter Property="Effect" Value="{x:Null}"/>
							<Style.Triggers>
								<Trigger Property="IsMouseOver" Value="True">
									<Setter Property="Background" Value="#14FFB74D"/>
									<Setter Property="Effect">
										<Setter.Value>
											<DropShadowEffect Color="#FFB74D" BlurRadius="10" ShadowDepth="0" Opacity="0.45"/>
										</Setter.Value>
									</Setter>
								</Trigger>
							</Style.Triggers>
						</Style>
					</Border.Style>
					<TextBlock FontSize="12" HorizontalAlignment="Center">
						<Hyperlink Click="NeopleApiLogo_Click"
								   TextDecorations="{x:Null}"
								   ToolTip="Neople Developers 열기">
							<Hyperlink.Style>
								<Style TargetType="Hyperlink">
									<Setter Property="TextDecorations" Value="{x:Null}"/>
									<Setter Property="Cursor" Value="Hand"/>
								</Style>
							</Hyperlink.Style>
							<Run Text="Powered by" Foreground="{DynamicResource SecondaryTextBrush}"/>
							<Run Text="Neople" Foreground="#FFFFA000"/>
							<Run Text="OpenAPI" Foreground="{DynamicResource PrimaryTextBrush}"/>
						</Hyperlink>
					</TextBlock>
				</Border>
			</StackPanel>

			<TextBlock x:Name="AppVersionText"
					   Grid.RowSpan="4"
					   Panel.ZIndex="10"
					   Foreground="{DynamicResource SecondaryTextBrush}"
					   FontSize="11"
					   Opacity="0.55"
					   IsHitTestVisible="False"
					   VerticalAlignment="Bottom"
					   HorizontalAlignment="Left"
					   Margin="0 0 0 8"/>

			<StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
				<Button Content="취소" Width="78" Height="32" Margin="0 0 8 0" IsCancel="True"/>
				<Button Content="저장" Width="78" Height="32" IsDefault="True" Click="Save_Click"/>
			</StackPanel>
		</Grid>
	</Border>
</Window>
