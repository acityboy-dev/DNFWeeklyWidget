<Window x:Class="DNFWeeklyWidget.MainWindow"
		xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:local="clr-namespace:DNFWeeklyWidget"
		xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
		Width="720" Height="720"
		MinWidth="720" MinHeight="480"
		WindowStyle="None"
		AllowsTransparency="False"
		Background="Transparent"
		ResizeMode="CanResize"
		Topmost="False"
		ShowInTaskbar="False"
		SizeChanged="Window_SizeChanged"
		LocationChanged="Window_LocationChanged"
		PreviewKeyDown="Window_PreviewKeyDown"
		MouseLeftButtonDown="Window_MouseLeftButtonDown">

	<shell:WindowChrome.WindowChrome>
		<shell:WindowChrome CaptionHeight="0"
							GlassFrameThickness="0"
							ResizeBorderThickness="8"
							UseAeroCaptionButtons="False"/>
	</shell:WindowChrome.WindowChrome>

	<Window.Resources>
		<BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
		<local:CachedImageSourceConverter x:Key="CachedImageSourceConverter"/>
		<SolidColorBrush x:Key="PrimaryTextBrush" Color="White"/>
		<SolidColorBrush x:Key="SecondaryTextBrush" Color="#99FFFFFF"/>
		<SolidColorBrush x:Key="TertiaryTextBrush" Color="#AAFFFFFF"/>
		<SolidColorBrush x:Key="CompletedTextBrush" Color="#7EDC9A"/>
		<SolidColorBrush x:Key="BlockedTextBrush" Color="#FF6B6B"/>
		<SolidColorBrush x:Key="CardBackgroundBrush" Color="#22FFFFFF"/>
		<SolidColorBrush x:Key="RemoveButtonBackgroundBrush" Color="#DD2A2D33"/>
		<SolidColorBrush x:Key="RemoveButtonBorderBrush" Color="#55FFFFFF"/>
		<SolidColorBrush x:Key="ButtonBackgroundBrush" Color="#14FFFFFF"/>
		<SolidColorBrush x:Key="ButtonHoverBackgroundBrush" Color="#22FFFFFF"/>
		<SolidColorBrush x:Key="ButtonPressedBackgroundBrush" Color="#33FFFFFF"/>
		<SolidColorBrush x:Key="ScrollThumbBrush" Color="#66FFFFFF"/>
		<SolidColorBrush x:Key="ScrollThumbHoverBrush" Color="#88FFFFFF"/>
		<SolidColorBrush x:Key="ScrollThumbPressedBrush" Color="#AAFFFFFF"/>
		<SolidColorBrush x:Key="InputBackgroundBrush" Color="#1AFFFFFF"/>
		<SolidColorBrush x:Key="InputBorderBrush" Color="#44FFFFFF"/>
		<SolidColorBrush x:Key="InputFocusedBorderBrush" Color="#88FFFFFF"/>
		<SolidColorBrush x:Key="InputSelectionBrush" Color="#6688C7FF"/>
		<SolidColorBrush x:Key="EpicLootTextBrush" Color="#FFFFB400"/>
		<SolidColorBrush x:Key="PrimevalLootTextBrush" Color="#FF58C8FA"/>
		<Style x:Key="InvisibleScrollBarButtonStyle" TargetType="RepeatButton">
			<Setter Property="Focusable" Value="False"/>
			<Setter Property="IsTabStop" Value="False"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="RepeatButton">
						<Border Background="Transparent"/>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<Style x:Key="PillScrollThumbStyle" TargetType="Thumb">
			<Setter Property="MinHeight" Value="24"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Thumb">
						<Rectangle x:Name="ThumbPill"
								   Width="8"
								   Margin="0"
								   HorizontalAlignment="Center"
								   VerticalAlignment="Stretch"
								   Fill="{DynamicResource ScrollThumbBrush}"
								   RadiusX="4"
								   RadiusY="4"
								   UseLayoutRounding="False"
								   SnapsToDevicePixels="False"/>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter TargetName="ThumbPill" Property="Width" Value="10"/>
								<Setter TargetName="ThumbPill" Property="RadiusX" Value="5"/>
								<Setter TargetName="ThumbPill" Property="RadiusY" Value="5"/>
								<Setter TargetName="ThumbPill" Property="Fill" Value="{DynamicResource ScrollThumbHoverBrush}"/>
							</Trigger>
							<Trigger Property="IsDragging" Value="True">
								<Setter TargetName="ThumbPill" Property="Width" Value="10"/>
								<Setter TargetName="ThumbPill" Property="RadiusX" Value="5"/>
								<Setter TargetName="ThumbPill" Property="RadiusY" Value="5"/>
								<Setter TargetName="ThumbPill" Property="Fill" Value="{DynamicResource ScrollThumbPressedBrush}"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<Style TargetType="ScrollBar">
			<Setter Property="Width" Value="12"/>
			<Setter Property="MinWidth" Value="12"/>
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="ScrollBar">
						<Grid Background="Transparent"
							  ClipToBounds="False">
							<Track x:Name="PART_Track"
								   IsDirectionReversed="True"
								   Margin="0 5"
								   ClipToBounds="False">
								<Track.DecreaseRepeatButton>
									<RepeatButton Command="ScrollBar.PageUpCommand"
												  Style="{StaticResource InvisibleScrollBarButtonStyle}"/>
								</Track.DecreaseRepeatButton>
								<Track.Thumb>
									<Thumb Style="{StaticResource PillScrollThumbStyle}"/>
								</Track.Thumb>
								<Track.IncreaseRepeatButton>
									<RepeatButton Command="ScrollBar.PageDownCommand"
												  Style="{StaticResource InvisibleScrollBarButtonStyle}"/>
								</Track.IncreaseRepeatButton>
							</Track>
						</Grid>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<Style TargetType="Button">
			<Setter Property="FocusVisualStyle" Value="{x:Null}"/>
			<Setter Property="Background" Value="{DynamicResource ButtonBackgroundBrush}"/>
			<Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
			<Setter Property="BorderBrush" Value="Transparent"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="Padding" Value="10 4"/>
			<Setter Property="Cursor" Value="Hand"/>
			<Setter Property="HorizontalContentAlignment" Value="Center"/>
			<Setter Property="VerticalContentAlignment" Value="Center"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border x:Name="ButtonChrome"
								Background="{TemplateBinding Background}"
								CornerRadius="8"
								SnapsToDevicePixels="True">
							<ContentPresenter x:Name="ContentHost"
											  Margin="{TemplateBinding Padding}"
											  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
											  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
											  RecognizesAccessKey="True"/>
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter Property="Background" Value="{DynamicResource ButtonHoverBackgroundBrush}"/>
							</Trigger>
							<Trigger Property="IsPressed" Value="True">
								<Setter Property="Background" Value="{DynamicResource ButtonPressedBackgroundBrush}"/>
								<Setter TargetName="ContentHost" Property="RenderTransform">
									<Setter.Value>
										<TranslateTransform Y="1"/>
									</Setter.Value>
								</Setter>
							</Trigger>
							<Trigger Property="IsEnabled" Value="False">
								<Setter Property="Opacity" Value="0.45"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<Style x:Key="PresetEdgeButtonStyle" TargetType="Button">
			<Setter Property="FocusVisualStyle" Value="{x:Null}"/>
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="BorderBrush" Value="Transparent"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="Padding" Value="0"/>
			<Setter Property="Cursor" Value="Hand"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Grid x:Name="EdgeHitArea"
							  Background="Transparent"
							  ClipToBounds="False">
							<Border x:Name="EdgeLine"
									Width="1"
									HorizontalAlignment="Left"
									Background="{DynamicResource InputBorderBrush}"
									Opacity="0.28"/>
							<Border x:Name="ArrowSpot"
									Width="28"
									Height="48"
									HorizontalAlignment="Left"
									VerticalAlignment="Center"
									Background="Transparent">
								<ContentPresenter HorizontalAlignment="Center"
												  VerticalAlignment="Center"/>
							</Border>
						</Grid>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter TargetName="EdgeLine" Property="Opacity" Value="0.72"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<Style x:Key="HudLabelStyle" TargetType="TextBlock">
			<Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
			<Setter Property="FontSize" Value="12"/>
			<Setter Property="FontWeight" Value="SemiBold"/>
			<Setter Property="VerticalAlignment" Value="Center"/>
		</Style>

		<Style x:Key="CardRemoveButtonStyle" TargetType="Button">
			<Setter Property="Visibility" Value="Collapsed"/>
			<Setter Property="Width" Value="24"/>
			<Setter Property="Height" Value="24"/>
			<Setter Property="HorizontalAlignment" Value="Right"/>
			<Setter Property="VerticalAlignment" Value="Top"/>
			<Setter Property="Margin" Value="0 -8 -8 0"/>
			<Setter Property="FontSize" Value="16"/>
			<Setter Property="FontWeight" Value="Bold"/>
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
			<Setter Property="BorderBrush" Value="Transparent"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="Padding" Value="0"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<ContentPresenter HorizontalAlignment="Center"
										  VerticalAlignment="Center"
										  RecognizesAccessKey="True"/>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
			<Style.Triggers>
				<DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Border}}" Value="True">
					<Setter Property="Visibility" Value="Visible"/>
				</DataTrigger>
				<Trigger Property="IsMouseOver" Value="True">
					<Setter Property="Foreground" Value="{DynamicResource BlockedTextBrush}"/>
				</Trigger>
			</Style.Triggers>
		</Style>

		<Style x:Key="CharacterCardStyle" TargetType="Border">
			<Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
			<Setter Property="ClipToBounds" Value="True"/>
			<Setter Property="BorderBrush" Value="Transparent"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="CornerRadius" Value="14"/>
			<Setter Property="Padding" Value="12"/>
			<Setter Property="MinHeight" Value="0"/>
			<Style.Triggers>
				<DataTrigger Binding="{Binding IsDragging}" Value="True">
					<Setter Property="Opacity" Value="0.35"/>
				</DataTrigger>
				<DataTrigger Binding="{Binding IsDropIndicator}" Value="True">
					<Setter Property="Background" Value="{DynamicResource ButtonHoverBackgroundBrush}"/>
					<Setter Property="BorderBrush" Value="{DynamicResource InputFocusedBorderBrush}"/>
					<Setter Property="BorderThickness" Value="1"/>
					<Setter Property="CornerRadius" Value="14"/>
					<Setter Property="Padding" Value="12"/>
					<Setter Property="MinHeight" Value="380"/>
					<Setter Property="Opacity" Value="0.75"/>
				</DataTrigger>
			</Style.Triggers>
		</Style>

		<Style x:Key="SummaryLineTextStyle" TargetType="TextBlock">
			<Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
			<Setter Property="FontSize" Value="13"/>
			<Setter Property="LineHeight" Value="18"/>
			<Setter Property="TextWrapping" Value="Wrap"/>
			<Style.Triggers>
				<DataTrigger Binding="{Binding IsCleared}" Value="True">
					<Setter Property="Foreground" Value="{DynamicResource CompletedTextBrush}"/>
				</DataTrigger>
				<DataTrigger Binding="{Binding IsLimitedOut}" Value="True">
					<Setter Property="Foreground" Value="{DynamicResource TertiaryTextBrush}"/>
					<Setter Property="Opacity" Value="0.52"/>
					<Setter Property="TextDecorations" Value="Strikethrough"/>
				</DataTrigger>
				<DataTrigger Binding="{Binding IsFameLocked}" Value="True">
					<Setter Property="Foreground" Value="{DynamicResource BlockedTextBrush}"/>
					<Setter Property="Opacity" Value="1"/>
					<Setter Property="TextDecorations" Value="{x:Null}"/>
				</DataTrigger>
			</Style.Triggers>
		</Style>

		<Style x:Key="SummaryLineMarkerStyle" TargetType="TextBlock">
			<Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
			<Setter Property="FontSize" Value="13"/>
			<Setter Property="LineHeight" Value="18"/>
			<Setter Property="Margin" Value="0 0 4 0"/>
			<Style.Triggers>
				<DataTrigger Binding="{Binding IsCleared}" Value="True">
					<Setter Property="Foreground" Value="{DynamicResource CompletedTextBrush}"/>
				</DataTrigger>
				<DataTrigger Binding="{Binding IsLimitedOut}" Value="True">
					<Setter Property="Foreground" Value="{DynamicResource TertiaryTextBrush}"/>
					<Setter Property="Opacity" Value="0.52"/>
				</DataTrigger>
				<DataTrigger Binding="{Binding IsFameLocked}" Value="True">
					<Setter Property="Foreground" Value="{DynamicResource BlockedTextBrush}"/>
					<Setter Property="Opacity" Value="1"/>
				</DataTrigger>
			</Style.Triggers>
		</Style>
	</Window.Resources>

	<Border x:Name="RootPanel"
			Background="Transparent"
			BorderThickness="0"
			Padding="22">

		<Grid>
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="*"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
			</Grid.RowDefinitions>

			<Border Grid.RowSpan="5"
					Width="36"
					Margin="-22 -22 0 -22"
					HorizontalAlignment="Left"
					Background="{DynamicResource ButtonHoverBackgroundBrush}"
					IsHitTestVisible="False"
					Panel.ZIndex="19">
				<Border.OpacityMask>
					<LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
						<GradientStop Color="#FF000000" Offset="0"/>
						<GradientStop Color="#B8000000" Offset="0.32"/>
						<GradientStop Color="#48000000" Offset="0.68"/>
						<GradientStop Color="#00000000" Offset="1"/>
					</LinearGradientBrush>
				</Border.OpacityMask>
				<Border.Style>
					<Style TargetType="Border">
						<Setter Property="Opacity" Value="0"/>
						<Style.Triggers>
							<DataTrigger Binding="{Binding IsMouseOver, ElementName=PresetPanelButton}" Value="True">
								<Setter Property="Opacity" Value="0.9"/>
							</DataTrigger>
							<DataTrigger Binding="{Binding IsPressed, ElementName=PresetPanelButton}" Value="True">
								<Setter Property="Opacity" Value="1"/>
							</DataTrigger>
						</Style.Triggers>
					</Style>
				</Border.Style>
			</Border>

			<Button x:Name="PresetPanelButton"
					Style="{StaticResource PresetEdgeButtonStyle}"
					Grid.RowSpan="5"
					Width="28"
					Padding="0"
					HorizontalAlignment="Left"
					VerticalAlignment="Stretch"
					Margin="-22 -22 0 -22"
					Panel.ZIndex="20"
					ToolTip="카드 엔트리 프리셋"
					PreviewMouseLeftButtonDown="PresetPanelButton_PreviewMouseLeftButtonDown"
					Click="PresetPanelButton_Click">
				<Path x:Name="PresetPanelArrow"
					  Data="M 11 4 L 7 8 L 11 12"
					  Stroke="{DynamicResource PrimaryTextBrush}"
					  StrokeThickness="1.2"
					  StrokeStartLineCap="Round"
					  StrokeEndLineCap="Round"
					  StrokeLineJoin="Round"
					  Stretch="Uniform"
					  Width="8"
					  Height="14"/>
			</Button>

			<Popup x:Name="PresetPanelPopup"
				   PlacementTarget="{Binding ElementName=RootPanel}"
				   Placement="Left"
				   HorizontalOffset="-12"
				   AllowsTransparency="True"
				   StaysOpen="False"
				   Opened="PresetPanelPopup_Opened"
				   Closed="PresetPanelPopup_Closed">
				<Border x:Name="PresetPanelHost"
						Width="210"
						Background="{DynamicResource InputDropDownBackgroundBrush}"
						BorderBrush="{DynamicResource InputBorderBrush}"
						BorderThickness="1"
						CornerRadius="10"
						Padding="10"
						RenderTransformOrigin="0,0.5">
					<Border.RenderTransform>
						<TranslateTransform X="14"/>
					</Border.RenderTransform>
					<StackPanel>
						<Grid Margin="0 0 0 8">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="28"/>
								<ColumnDefinition Width="6"/>
								<ColumnDefinition Width="28"/>
							</Grid.ColumnDefinitions>
							<TextBlock Text="프리셋"
									   Foreground="{DynamicResource PrimaryTextBrush}"
									   FontSize="13"
									   FontWeight="SemiBold"
									   VerticalAlignment="Center"/>
							<Button Grid.Column="1"
									Content="+"
									Width="28"
									Height="26"
									Padding="0"
									Click="AddPreset_Click"/>
							<Button Grid.Column="3"
									Content="-"
									Width="28"
									Height="26"
									Padding="0"
									Click="RemovePreset_Click"/>
						</Grid>
						<ListBox x:Name="PresetListBox"
								 MaxHeight="220"
								 BorderThickness="0"
								 Background="Transparent"
								 SelectionChanged="PresetListBox_SelectionChanged">
							<ListBox.ItemContainerStyle>
								<Style TargetType="ListBoxItem">
									<Setter Property="HorizontalContentAlignment" Value="Stretch"/>
								</Style>
							</ListBox.ItemContainerStyle>
							<ListBox.ItemTemplate>
								<DataTemplate>
									<Grid Margin="0 1">
										<Grid.ColumnDefinitions>
											<ColumnDefinition Width="*"/>
											<ColumnDefinition Width="22"/>
										</Grid.ColumnDefinitions>
										<TextBlock x:Name="PresetNameText"
												   Text="{Binding Name}"
												   Foreground="{DynamicResource PrimaryTextBrush}"
												   FontSize="13"
												   Padding="4 5"
												   VerticalAlignment="Center"
												   TextTrimming="CharacterEllipsis"/>
										<Button Grid.Column="1"
												Tag="{Binding}"
												Width="20"
												Height="24"
												Padding="0"
												HorizontalAlignment="Right"
												ToolTip="프리셋명 수정"
												Click="EditPreset_Click">
											<Path Data="M 3 11 L 3.5 8.5 L 9 3 L 11 5 L 5.5 10.5 Z M 8.4 3.6 L 10.4 5.6"
												  Stroke="{DynamicResource SecondaryTextBrush}"
												  StrokeThickness="1"
												  StrokeStartLineCap="Round"
												  StrokeEndLineCap="Round"
												  StrokeLineJoin="Round"
												  Stretch="Uniform"
												  Width="11"
												  Height="11"/>
										</Button>
									</Grid>
								</DataTemplate>
							</ListBox.ItemTemplate>
						</ListBox>
					</StackPanel>
				</Border>
			</Popup>

			<Border x:Name="PresetNameEditorPanel"
					Grid.RowSpan="5"
					Width="250"
					Margin="8 0 0 0"
					Padding="12"
					HorizontalAlignment="Left"
					VerticalAlignment="Center"
					Background="{DynamicResource InputDropDownBackgroundBrush}"
					BorderBrush="{DynamicResource InputFocusedBorderBrush}"
					BorderThickness="1"
					CornerRadius="10"
					Visibility="Collapsed"
					Panel.ZIndex="80">
				<StackPanel>
					<TextBlock Text="프리셋 이름"
							   Margin="0 0 0 8"
							   Foreground="{DynamicResource PrimaryTextBrush}"
							   FontSize="13"
							   FontWeight="SemiBold"/>
					<TextBox x:Name="PresetNameEditorBox"
							 Height="34"
							 FontSize="15"
							 LostFocus="PresetNameEditorBox_LostFocus"
							 KeyDown="PresetNameEditorBox_KeyDown"/>
					<TextBlock Text="Enter 저장  ·  Esc 취소"
							   Margin="2 7 0 0"
							   Foreground="{DynamicResource SecondaryTextBrush}"
							   FontSize="11"/>
				</StackPanel>
			</Border>

			<Grid x:Name="TitleBar"
				  Grid.Row="0"
				  Margin="0 0 0 18">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="Auto"/>
				</Grid.ColumnDefinitions>
				<Grid Margin="0 0 12 0">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="Auto"/>
						<ColumnDefinition Width="*"/>
					</Grid.ColumnDefinitions>
					<TextBlock x:Name="TitleText"
							   Text="DNF Weekly Widget"
							   FontFamily="Segoe UI Variable Display, Segoe UI"
							   Foreground="{DynamicResource PrimaryTextBrush}"
							   FontSize="24"
							   FontWeight="Regular"
							   VerticalAlignment="Center"/>
					<TextBlock x:Name="CurrentPresetNameText"
							   Grid.Column="1"
							   Foreground="{DynamicResource TertiaryTextBrush}"
							   FontSize="13"
							   VerticalAlignment="Center"
							   TextTrimming="CharacterEllipsis"
							   Margin="10 3 0 0"/>
				</Grid>

				<StackPanel Grid.Column="1"
							Orientation="Horizontal"
							HorizontalAlignment="Right"
							VerticalAlignment="Center">
					<Button x:Name="RaidVisibilityButton"
							Content="레이드 미표시"
							Width="102"
							Height="34"
							FontSize="13"
							Margin="0 0 8 0"
							ToolTip="카드의 레이드 콘텐츠 표시 전환"
							Click="RaidVisibility_Click"/>
					<Button x:Name="IncompleteFilterButton"
							Content="미완료만"
							Width="76"
							Height="34"
							FontSize="13"
							Margin="0 0 8 0"
							ToolTip="미완료 콘텐츠가 있는 카드만 보기"
							Click="IncompleteFilter_Click"/>
					<Button x:Name="FameSortButton"
							Content="명성순"
							Width="64"
							Height="34"
							FontSize="13"
							Margin="0 0 8 0"
							ToolTip="명성순 자동 정렬"
							Click="FameSort_Click"/>
					<Button x:Name="ClearAllButton"
							Content="전체삭제"
							Width="70"
							Height="34"
							FontSize="13"
							Margin="0 0 18 0"
							ToolTip="전체 카드 엔트리 삭제"
							Click="ClearAllCharacters_Click"/>
					<Button x:Name="RefreshNowButton"
							Width="88"
							Height="34"
							FontSize="14"
							Margin="0 0 8 0"
							Click="RefreshNow_Click">
						<Grid>
							<TextBlock x:Name="RefreshNowText"
									   Text="지금 갱신"
									   HorizontalAlignment="Center"
									   VerticalAlignment="Center"/>
							<Path x:Name="RefreshNowIcon"
								  Data="M 12.5 5.5 A 4.8 4.8 0 1 0 13 9 M 13 3 L 13 6 L 10 6"
								  Stroke="{DynamicResource PrimaryTextBrush}"
								  StrokeThickness="1"
								  StrokeStartLineCap="Round"
								  StrokeEndLineCap="Round"
								  StrokeLineJoin="Round"
								  Stretch="Uniform"
								  Width="16"
								  Height="16"
								  Visibility="Collapsed"/>
						</Grid>
					</Button>
					<Button x:Name="SettingsButton"
							Width="68"
							Height="34"
							FontSize="14"
							Margin="0 0 8 0"
							Click="Settings_Click">
						<Grid>
							<TextBlock x:Name="SettingsText"
									   Text="설정"
									   HorizontalAlignment="Center"
									   VerticalAlignment="Center"/>
                            <Path x:Name="SettingsIcon"
								  Data="M3 4.2 H4.8
										M7.4 4.2 H13
										M6.1 2.9
										A1.3 1.3 0 1 1 6.09 2.9

										M3 8 H8.6
										M11.2 8 H13
										M9.9 6.7
										A1.3 1.3 0 1 1 9.89 6.7

										M3 11.8 H6.3
										M8.9 11.8 H13
										M7.6 10.5
										A1.3 1.3 0 1 1 7.59 10.5"
								  Stroke="{DynamicResource PrimaryTextBrush}"
								  StrokeThickness="1"
								  StrokeStartLineCap="Round"
								  StrokeEndLineCap="Round"
								  StrokeLineJoin="Round"
								  Fill="Transparent"
								  Stretch="Uniform"
								  Width="16"
								  Height="16"/>	
                        </Grid>
					</Button>
					<Button x:Name="CompactModeButton"
							Width="36"
							Height="34"
							Margin="0 0 8 0"
							Padding="0"
							ToolTip="컴팩트 모드 전환"
							Click="CompactMode_Click">
						<Path x:Name="CompactModeIcon"
							  Data="M 2 10 L 8 4 L 14 10 M 2 15 L 14 15"
							  Stroke="{DynamicResource PrimaryTextBrush}"
							  StrokeThickness="1"
							  StrokeStartLineCap="Round"
							  StrokeEndLineCap="Round"
							  Stretch="Uniform"
							  Width="16"
							  Height="16"/>
					</Button>
					<Button x:Name="CloseButton"
							Width="36"
							Height="34"
							Padding="0"
							HorizontalAlignment="Right"
							Click="Close_Click">
						<Path x:Name="CloseIcon"
							  Data="M 3 3 L 13 13 M 13 3 L 3 13"
							  Stroke="{DynamicResource PrimaryTextBrush}"
							  StrokeThickness="1"
							  StrokeStartLineCap="Round"
							  StrokeEndLineCap="Round"
							  Stretch="Uniform"
							  Width="16"
							  Height="16"/>
					</Button>
				</StackPanel>
			</Grid>

			<StackPanel Grid.Row="1" Margin="0 0 0 18" Visibility="Collapsed">
				<DockPanel Margin="0 0 0 10">
					<TextBox x:Name="OldAdventureNameBox"
							 Width="336"
							 Height="34"
							 FontSize="15"
							 Margin="0 0 10 0"/>
					<Button Content="던담 모험단 적용"
							Width="128"
							Height="34"
							FontSize="14"
							Click="ImportAdventure_Click"/>
				</DockPanel>

				<DockPanel Margin="0 0 0 10">
					<ComboBox x:Name="OldServerComboBox"
							  Width="120"
							  Height="34"
							  FontSize="15"
							  DisplayMemberPath="Name"
							  SelectedValuePath="Id"
							  Margin="0 0 10 0"/>
					<TextBox x:Name="OldCharacterNameBox"
							 Width="258"
							 Height="34"
							 FontSize="15"
							 Margin="0 0 10 0"
							 KeyDown="CharacterNameBox_KeyDown"/>
					<Button Content="추가"
							Width="80"
							Height="34"
							FontSize="14"
							Click="AddCharacter_Click"/>
				</DockPanel>

				<DockPanel>
					<TextBlock Text="한 줄 카드 수"
							   Foreground="{DynamicResource PrimaryTextBrush}"
							   FontSize="14"
							   VerticalAlignment="Center"
							   Margin="0 0 10 0"/>
					<TextBox x:Name="OldColumnsBox"
							 Width="56"
							 Height="32"
							 FontSize="15"
							 Text="2"/>
					<Button Content="지금 갱신"
							Width="112"
							Height="32"
							FontSize="14"
							Margin="12 0 0 0"
							Click="RefreshNow_Click"/>
				</DockPanel>
			</StackPanel>

			<Grid x:Name="HudPanel"
				  Grid.Row="1"
				  Margin="0 0 0 18"
				  ClipToBounds="True">
				<Grid.RowDefinitions>
					<RowDefinition Height="34"/>
					<RowDefinition Height="10"/>
					<RowDefinition Height="34"/>
				</Grid.RowDefinitions>

				<Grid Grid.Row="0">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="58"/>
						<ColumnDefinition Width="10"/>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="10"/>
						<ColumnDefinition Width="Auto"/>
						<ColumnDefinition Width="10"/>
						<ColumnDefinition Width="Auto"/>
						<ColumnDefinition Width="10"/>
						<ColumnDefinition Width="Auto"/>
					</Grid.ColumnDefinitions>
					<TextBlock Grid.Column="0"
							   Text="모험단"
							   Style="{StaticResource HudLabelStyle}"/>
					<TextBox x:Name="AdventureNameBox"
							 Grid.Column="2"
							 Height="34"
							 FontSize="15"
							 PreviewKeyDown="HudTextBox_PreviewKeyDown"
							 KeyDown="AdventureNameBox_KeyDown"/>
					<CheckBox x:Name="KeepExistingCharactersOnImportBox"
							  Grid.Column="4"
							  Content="기존 캐릭터 유지"
							  IsChecked="False"
							  FontSize="13"
							  ToolTip="체크하지 않으면 현재 프리셋의 캐릭터 목록을 던담 모험단 목록으로 교체합니다.&#10;체크하면 기존 캐릭터를 유지하고 중복을 제외한 캐릭터만 추가합니다."
							  VerticalAlignment="Center"/>
					<CheckBox x:Name="RemoveAdventureCharactersBox"
							  Grid.Column="6"
							  Content="모험단 빼기"
							  IsChecked="False"
							  FontSize="13"
							  ToolTip="던담 모험단과 일치하는 캐릭터를 현재 프리셋에서 제거합니다."
							  VerticalAlignment="Center"
							  Click="RemoveAdventureCharactersBox_Click"/>
					<Button x:Name="ImportAdventureButton"
							Grid.Column="8"
							Content="던담에서 리스트 불러오기"
							MinWidth="186"
							Height="34"
							FontSize="14"
							Click="ImportAdventure_Click"/>
				</Grid>

				<Grid Grid.Row="2">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="58"/>
						<ColumnDefinition Width="10"/>
						<ColumnDefinition Width="112"/>
						<ColumnDefinition Width="8"/>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="8"/>
						<ColumnDefinition Width="64"/>
					</Grid.ColumnDefinitions>
					<TextBlock Grid.Column="0"
							   Text="캐릭터"
							   Style="{StaticResource HudLabelStyle}"/>
					<ComboBox x:Name="ServerComboBox"
							  Grid.Column="2"
							  Height="34"
							  FontSize="15"
							  DisplayMemberPath="Name"
							  SelectedValuePath="Id"/>
					<TextBox x:Name="CharacterNameBox"
							 Grid.Column="4"
							 Height="34"
							 FontSize="15"
							 PreviewKeyDown="HudTextBox_PreviewKeyDown"
							 KeyDown="CharacterNameBox_KeyDown"/>
					<Button Grid.Column="6"
							Content="추가"
							Height="34"
							FontSize="14"
							Click="AddCharacter_Click"/>
				</Grid>

			</Grid>

			<Grid Grid.Row="2">
				<ScrollViewer x:Name="CharacterScrollViewer"
							  VerticalScrollBarVisibility="Visible"
							  HorizontalScrollBarVisibility="Disabled"
							  Margin="0 0 -14 0"
							  Padding="0 0 6 0"
							  SizeChanged="CharacterScrollViewer_SizeChanged"
							  ScrollChanged="CharacterScrollViewer_ScrollChanged"
							  PreviewMouseWheel="CharacterScrollViewer_PreviewMouseWheel">
					<ItemsControl x:Name="CharacterList"
								  Tag="2"
								  AllowDrop="True"
								  DragOver="CharacterList_DragOver"
								  Drop="CharacterList_Drop">
						<ItemsControl.ItemsPanel>
							<ItemsPanelTemplate>
								<local:FixedColumnWrapPanel Columns="{Binding Tag, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
															ItemSpacing="12"/>
							</ItemsPanelTemplate>
						</ItemsControl.ItemsPanel>
						<ItemsControl.ItemContainerStyle>
							<Style TargetType="ContentPresenter">
								<Setter Property="HorizontalAlignment" Value="Stretch"/>
								<Setter Property="VerticalAlignment" Value="Stretch"/>
							</Style>
						</ItemsControl.ItemContainerStyle>

						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<Border Width="{Binding CardWidth}"
										VerticalAlignment="Stretch"
										Style="{StaticResource CharacterCardStyle}"
										AllowDrop="True"
										PreviewMouseLeftButtonDown="CharacterCard_PreviewMouseLeftButtonDown"
										MouseMove="CharacterCard_MouseMove"
										GiveFeedback="CharacterCard_GiveFeedback"
										QueryContinueDrag="CharacterCard_QueryContinueDrag"
										DragOver="CharacterCard_DragOver"
										Drop="CharacterCard_Drop">
									<Grid VerticalAlignment="Top"
										  ClipToBounds="True">
										<Grid.Style>
											<Style TargetType="Grid">
												<Setter Property="Visibility" Value="Visible"/>
												<Style.Triggers>
													<DataTrigger Binding="{Binding IsDropIndicator}" Value="True">
														<Setter Property="Visibility" Value="Collapsed"/>
													</DataTrigger>
												</Style.Triggers>
											</Style>
										</Grid.Style>

										<StackPanel ClipToBounds="True">
											<Border Height="150"
													ClipToBounds="True"
													Margin="0 -4 0 10"
													Visibility="{Binding ShowFullImage, Converter={StaticResource BoolToVisibilityConverter}}">
												<Grid>
													<Image Source="{Binding ImageSource}"
														   Stretch="None"
														   HorizontalAlignment="Center"
														   VerticalAlignment="Top"
														   Margin="0 -58 0 0"
														   Visibility="{Binding ShowFullCharacterImage, Converter={StaticResource BoolToVisibilityConverter}}"/>
													<Grid Width="78"
														  Height="78"
														  HorizontalAlignment="Center"
														  VerticalAlignment="Center"
														  Visibility="{Binding ShowFullImagePlaceholder, Converter={StaticResource BoolToVisibilityConverter}}">
														<Ellipse Fill="{DynamicResource ButtonHoverBackgroundBrush}"/>
														<TextBlock Text="?"
																   Foreground="{DynamicResource SecondaryTextBrush}"
																   FontSize="34"
																   FontWeight="SemiBold"
																   HorizontalAlignment="Center"
																   VerticalAlignment="Center"
																   Margin="0 -3 0 0"/>
													</Grid>
												</Grid>
											</Border>

											<Grid Margin="0 0 0 8"
												  Visibility="{Binding ShowCompactImage, Converter={StaticResource BoolToVisibilityConverter}}">
												<Grid.ColumnDefinitions>
													<ColumnDefinition Width="40"/>
													<ColumnDefinition Width="*"/>
												</Grid.ColumnDefinitions>
												<Grid Width="34"
													  Height="34"
													  ClipToBounds="True"
													  Background="Transparent"
													  VerticalAlignment="Center">
													<Grid.Clip>
														<EllipseGeometry Center="17,17"
																		 RadiusX="17"
																		 RadiusY="17"/>
													</Grid.Clip>
													<Image Source="{Binding ImageSource}"
														   Stretch="None"
														   HorizontalAlignment="Left"
														   VerticalAlignment="Top"
														   Margin="{Binding CompactImageMargin}"
														   Visibility="{Binding ShowCompactCharacterImage, Converter={StaticResource BoolToVisibilityConverter}}"/>
													<Grid Visibility="{Binding ShowCompactImagePlaceholder, Converter={StaticResource BoolToVisibilityConverter}}">
														<Ellipse Fill="{DynamicResource ButtonHoverBackgroundBrush}"/>
														<TextBlock Text="?"
																   Foreground="{DynamicResource SecondaryTextBrush}"
																   FontSize="17"
																   FontWeight="SemiBold"
																   HorizontalAlignment="Center"
																   VerticalAlignment="Center"
																   Margin="0 -1 0 0"/>
													</Grid>
												</Grid>
												<StackPanel Grid.Column="1"
															VerticalAlignment="Center">
													<TextBlock Text="{Binding CharacterName}"
															   Foreground="{DynamicResource PrimaryTextBrush}"
															   FontSize="16"
															   FontWeight="Bold"
															   TextWrapping="NoWrap"
															   TextTrimming="CharacterEllipsis"/>
													<TextBlock Text="{Binding ServerName}"
															   Foreground="{DynamicResource SecondaryTextBrush}"
															   FontSize="12"
															   Margin="0 2 0 0"
															   TextTrimming="CharacterEllipsis"/>
												</StackPanel>
											</Grid>

											<TextBlock Text="{Binding CharacterName}"
													   Foreground="{DynamicResource PrimaryTextBrush}"
													   FontSize="16"
													   FontWeight="Bold"
													   TextWrapping="NoWrap"
													   TextTrimming="CharacterEllipsis"
													   Visibility="{Binding ShowStandardHeader, Converter={StaticResource BoolToVisibilityConverter}}"/>

											<TextBlock Text="{Binding ServerName}"
													   Foreground="{DynamicResource SecondaryTextBrush}"
													   FontSize="12"
													   Margin="0 2 0 0"
													   TextTrimming="CharacterEllipsis"
													   Visibility="{Binding ShowStandardHeader, Converter={StaticResource BoolToVisibilityConverter}}"/>

											<local:MarqueeTextBlock Text="{Binding MetaSummary}"
																	Foreground="{DynamicResource PrimaryTextBrush}"
																	FontSize="13"
																	Height="19"
																	HorizontalAlignment="Stretch"
																	Margin="0 6 0 0"/>

											<Border Height="1"
													Background="{DynamicResource InputBorderBrush}"
													Opacity="0.55"
													Margin="0 8 0 7"/>

											<ItemsControl ItemsSource="{Binding SummaryLines}"
														  ClipToBounds="True"
														  Visibility="{Binding IsCompactLayout, Converter={StaticResource BoolToVisibilityConverter}}">
												<ItemsControl.ItemTemplate>
													<DataTemplate>
														<Grid>
															<Border x:Name="SummarySeparator"
																	Height="1"
																	Background="{DynamicResource InputBorderBrush}"
																	Opacity="0.42"
																	Margin="0 6 0 6"
																	Visibility="Collapsed"/>
															<Grid x:Name="SummaryTextLine"
																  Margin="0 0 0 1">
																<Grid.ColumnDefinitions>
																	<ColumnDefinition Width="Auto"/>
																	<ColumnDefinition Width="*"/>
																</Grid.ColumnDefinitions>
																<TextBlock Text="{Binding Marker}"
																		   Style="{StaticResource SummaryLineMarkerStyle}"/>
																<TextBlock x:Name="SummaryBodyText"
																		   Grid.Column="1"
																		   Text="{Binding Body}"
																		   Style="{StaticResource SummaryLineTextStyle}"/>
																<TextBlock x:Name="SummaryWeeklyLootText"
																		   Grid.Column="1"
																		   Style="{StaticResource SummaryLineTextStyle}"
																		   Visibility="Collapsed">
																	<Run Text="{Binding LootTitle}"/>
																	<Run Text=": "/>
																	<InlineUIContainer BaselineAlignment="Center">
																		<TextBlock Text="{Binding PrimevalCount}"
																				   FontSize="13"
																				   FontWeight="SemiBold"
																				   Foreground="{DynamicResource PrimevalLootTextBrush}"/>
																	</InlineUIContainer>
																	<Run Text="/"/>
																	<InlineUIContainer BaselineAlignment="Center">
																		<TextBlock Text="{Binding EpicCount}"
																				   FontSize="13"
																				   FontWeight="SemiBold"
																				   Foreground="{DynamicResource EpicLootTextBrush}"/>
																	</InlineUIContainer>
																</TextBlock>
															</Grid>
														</Grid>
														<DataTemplate.Triggers>
															<DataTrigger Binding="{Binding IsWeeklyLoot}" Value="True">
																<Setter TargetName="SummaryBodyText" Property="Visibility" Value="Collapsed"/>
																<Setter TargetName="SummaryWeeklyLootText" Property="Visibility" Value="Visible"/>
															</DataTrigger>
															<DataTrigger Binding="{Binding IsSeparator}" Value="True">
																<Setter TargetName="SummarySeparator" Property="Visibility" Value="Visible"/>
																<Setter TargetName="SummaryTextLine" Property="Visibility" Value="Collapsed"/>
															</DataTrigger>
														</DataTemplate.Triggers>
													</DataTemplate>
												</ItemsControl.ItemTemplate>
											</ItemsControl>

											<ItemsControl ItemsSource="{Binding SummaryParagraphs}"
														  Margin="0 -1 0 -4"
														  Visibility="{Binding IsWideLayout, Converter={StaticResource BoolToVisibilityConverter}}">
												<ItemsControl.ItemsPanel>
													<ItemsPanelTemplate>
														<WrapPanel/>
													</ItemsPanelTemplate>
											</ItemsControl.ItemsPanel>
											<ItemsControl.ItemTemplate>
												<DataTemplate>
													<Grid>
														<Border x:Name="SummarySeparator"
																Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
																Height="1"
																Background="{DynamicResource InputBorderBrush}"
																Opacity="0.42"
																Margin="0 6 0 8"
																Visibility="Collapsed"/>
														<Grid x:Name="SummaryTextLine"
															  MaxWidth="260"
															  Margin="0 0 16 5">
															<Grid.ColumnDefinitions>
																<ColumnDefinition Width="Auto"/>
																<ColumnDefinition Width="*"/>
															</Grid.ColumnDefinitions>
															<TextBlock Text="{Binding Marker}"
																	   Style="{StaticResource SummaryLineMarkerStyle}"/>
															<TextBlock x:Name="SummaryBodyText"
																	   Grid.Column="1"
																	   Text="{Binding Body}"
																	   Style="{StaticResource SummaryLineTextStyle}"/>
															<TextBlock x:Name="SummaryWeeklyLootText"
																	   Grid.Column="1"
																	   Style="{StaticResource SummaryLineTextStyle}"
																	   Visibility="Collapsed">
																<Run Text="{Binding LootTitle}"/>
																<Run Text=": "/>
																<InlineUIContainer BaselineAlignment="Center">
																	<TextBlock Text="{Binding PrimevalCount}"
																			   FontSize="13"
																			   FontWeight="SemiBold"
																			   Foreground="{DynamicResource PrimevalLootTextBrush}"/>
																</InlineUIContainer>
																<Run Text="/"/>
																<InlineUIContainer BaselineAlignment="Center">
																	<TextBlock Text="{Binding EpicCount}"
																			   FontSize="13"
																			   FontWeight="SemiBold"
																			   Foreground="{DynamicResource EpicLootTextBrush}"/>
																</InlineUIContainer>
															</TextBlock>
															<TextBlock x:Name="SummaryDetailedWeeklyLootText"
																	   Grid.Column="1"
																	   Style="{StaticResource SummaryLineTextStyle}"
																	   Visibility="Collapsed">
																<Run Text="{Binding LootTitle}"/>
																<Run Text=": 태초 "/>
																<InlineUIContainer BaselineAlignment="Center">
																	<TextBlock Text="{Binding PrimevalCount}"
																			   FontSize="13"
																			   FontWeight="SemiBold"
																			   Foreground="{DynamicResource PrimevalLootTextBrush}"/>
																</InlineUIContainer>
																<Run Text="/에픽 "/>
																<InlineUIContainer BaselineAlignment="Center">
																	<TextBlock Text="{Binding EpicCount}"
																			   FontSize="13"
																			   FontWeight="SemiBold"
																			   Foreground="{DynamicResource EpicLootTextBrush}"/>
																</InlineUIContainer>
															</TextBlock>
														</Grid>
													</Grid>
													<DataTemplate.Triggers>
														<DataTrigger Binding="{Binding IsWeeklyLoot}" Value="True">
															<Setter TargetName="SummaryBodyText" Property="Visibility" Value="Collapsed"/>
															<Setter TargetName="SummaryWeeklyLootText" Property="Visibility" Value="Visible"/>
														</DataTrigger>
														<DataTrigger Binding="{Binding DataContext.IsDetailedLootLayout, RelativeSource={RelativeSource AncestorType=ItemsControl}}" Value="True">
															<Setter TargetName="SummaryBodyText" Property="Text" Value="{Binding DetailedBody}"/>
														</DataTrigger>
														<MultiDataTrigger>
															<MultiDataTrigger.Conditions>
																<Condition Binding="{Binding IsWeeklyLoot}" Value="True"/>
																<Condition Binding="{Binding DataContext.IsDetailedLootLayout, RelativeSource={RelativeSource AncestorType=ItemsControl}}" Value="True"/>
															</MultiDataTrigger.Conditions>
															<Setter TargetName="SummaryWeeklyLootText" Property="Visibility" Value="Collapsed"/>
															<Setter TargetName="SummaryDetailedWeeklyLootText" Property="Visibility" Value="Visible"/>
														</MultiDataTrigger>
														<DataTrigger Binding="{Binding IsSeparator}" Value="True">
															<Setter TargetName="SummarySeparator" Property="Visibility" Value="Visible"/>
															<Setter TargetName="SummaryTextLine" Property="Visibility" Value="Collapsed"/>
														</DataTrigger>
													</DataTemplate.Triggers>
												</DataTemplate>
												</ItemsControl.ItemTemplate>
											</ItemsControl>

											<Border Margin="0 8 22 0"
													Padding="8 6"
													CornerRadius="6"
													Background="{DynamicResource ButtonBackgroundBrush}"
													Visibility="{Binding ShowMemoArea, Converter={StaticResource BoolToVisibilityConverter}}">
												<TextBlock Text="{Binding Memo}"
														   Foreground="{DynamicResource SecondaryTextBrush}"
														   FontSize="12"
														   TextWrapping="Wrap"/>
											</Border>
										</StackPanel>

										<Button Content="×"
												Tag="{Binding}"
												Style="{StaticResource CardRemoveButtonStyle}"
												Panel.ZIndex="5"
											Click="RemoveCharacter_Click"/>
									<Button Tag="{Binding}"
											Width="24"
											Height="24"
											Padding="4"
											HorizontalAlignment="Right"
											VerticalAlignment="Bottom"
											Margin="0"
											Background="Transparent"
											BorderThickness="0"
											ToolTip="메모 추가 또는 편집"
											Panel.ZIndex="5"
											Click="EditCardMemo_Click">
										<Path Data="M3 13 L4.2 9.4 L10.2 3.4 L12.6 5.8 L6.6 11.8 Z M4.2 9.4 L6.6 11.8 M9.4 4.2 L11.8 6.6"
												  Stroke="{DynamicResource SecondaryTextBrush}"
												  StrokeThickness="1.2"
												  StrokeLineJoin="Round"
												  Stretch="Uniform"/>
									</Button>
									</Grid>
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>
				</ScrollViewer>

			</Grid>

			<Border x:Name="IncompleteSummaryPanel"
					   Grid.Row="3"
					Background="{DynamicResource ButtonBackgroundBrush}"
					CornerRadius="10"
					Padding="10 8"
					Margin="0 8 0 0"
					Visibility="Visible">
				<StackPanel>
					<Grid x:Name="SummaryPanelHeader"
						  Margin="0 0 0 6"
						  Background="Transparent"
						  Cursor="Hand"
						  MouseLeftButtonDown="SummaryPanelHeader_MouseLeftButtonDown">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="Auto"/>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="24"/>
						</Grid.ColumnDefinitions>
						<TextBlock Text="요약"
								   Foreground="{DynamicResource SecondaryTextBrush}"
								   FontSize="12"
								   FontWeight="SemiBold"
								   VerticalAlignment="Center"/>
						<TextBlock x:Name="WeeklyResetText"
								   Grid.Column="1"
								   Foreground="{DynamicResource TertiaryTextBrush}"
								   FontSize="11"
								   Margin="12 0 4 0"
								   HorizontalAlignment="Right"
								   VerticalAlignment="Center"
								   TextTrimming="CharacterEllipsis"/>
						<Path x:Name="SummaryPanelToggleIcon"
							  Grid.Column="2"
							  Data="M 4 7 L 8 11 L 12 7"
							  Stroke="{DynamicResource SecondaryTextBrush}"
							  StrokeThickness="1.4"
							  StrokeStartLineCap="Round"
							  StrokeEndLineCap="Round"
							  Stretch="Uniform"
							  Width="12"
							  Height="12"
							  HorizontalAlignment="Center"
							  VerticalAlignment="Center"
							  IsHitTestVisible="False"/>
					</Grid>
					<Grid x:Name="SummaryPanelBody"
						  ClipToBounds="True">
						<Grid.ColumnDefinitions>
							<ColumnDefinition x:Name="IncompleteSummaryColumn" Width="*"/>
							<ColumnDefinition x:Name="SummaryColumnGap" Width="14"/>
							<ColumnDefinition x:Name="WeeklyLootSummaryColumn" Width="*"/>
						</Grid.ColumnDefinitions>
						<StackPanel>
							<TextBlock Text="미완료 요약"
									   Foreground="{DynamicResource SecondaryTextBrush}"
									   FontSize="12"
									   FontWeight="SemiBold"
									   Margin="0 0 0 6"/>
							<ItemsControl x:Name="IncompleteSummaryList">
								<ItemsControl.ItemTemplate>
									<DataTemplate>
										<Grid Margin="0 1 0 4">
											<Grid.ColumnDefinitions>
												<ColumnDefinition Width="Auto"/>
												<ColumnDefinition Width="*"/>
											</Grid.ColumnDefinitions>
											<TextBlock Text="{Binding Title}"
													   Foreground="{DynamicResource PrimaryTextBrush}"
													   FontSize="13"
													   FontWeight="SemiBold"
													   Margin="0 0 10 0"/>
											<TextBlock Grid.Column="1"
													   x:Name="IncompleteCharacterSummaryText"
													   Text="{Binding CharacterSummary}"
													   Foreground="{DynamicResource TertiaryTextBrush}"
													   FontSize="13"
													   TextWrapping="Wrap"/>
										</Grid>
										<DataTemplate.Triggers>
											<DataTrigger Binding="{Binding HasCharacterSummary}" Value="False">
												<Setter TargetName="IncompleteCharacterSummaryText" Property="Visibility" Value="Collapsed"/>
											</DataTrigger>
										</DataTemplate.Triggers>
									</DataTemplate>
								</ItemsControl.ItemTemplate>
							</ItemsControl>
						</StackPanel>
						<StackPanel x:Name="WeeklyLootSummarySection"
									Grid.Column="2">
							<TextBlock Text="주간 획득 요약"
									   Foreground="{DynamicResource SecondaryTextBrush}"
									   FontSize="12"
									   FontWeight="SemiBold"
									   Margin="0 0 0 6"/>
							<ItemsControl x:Name="WeeklyLootSummaryList">
								<ItemsControl.ItemTemplate>
									<DataTemplate>
										<Grid Margin="0 1 0 4">
											<Grid.ColumnDefinitions>
												<ColumnDefinition Width="Auto"/>
												<ColumnDefinition Width="*"/>
											</Grid.ColumnDefinitions>
											<TextBlock Text="{Binding Title}"
													   Foreground="{DynamicResource PrimaryTextBrush}"
													   FontSize="13"
													   FontWeight="SemiBold"
													   Margin="0 0 10 0"/>
											<TextBlock Grid.Column="1"
													   Foreground="{DynamicResource TertiaryTextBrush}"
													   FontSize="13"
													   TextWrapping="Wrap">
												<Run Text="태초 "/>
												<InlineUIContainer BaselineAlignment="Center">
													<TextBlock Text="{Binding PrimevalCount}"
															   FontSize="13"
															   FontWeight="SemiBold"
															   Foreground="{DynamicResource PrimevalLootTextBrush}"/>
												</InlineUIContainer>
												<Run Text="/에픽 "/>
												<InlineUIContainer BaselineAlignment="Center">
													<TextBlock Text="{Binding EpicCount}"
															   FontSize="13"
															   FontWeight="SemiBold"
															   Foreground="{DynamicResource EpicLootTextBrush}"/>
												</InlineUIContainer>
											</TextBlock>
										</Grid>
									</DataTemplate>
								</ItemsControl.ItemTemplate>
							</ItemsControl>
						</StackPanel>
					</Grid>
				</StackPanel>
			</Border>

			<TextBlock x:Name="StatusText"
					   Grid.Row="4"
					   Foreground="{DynamicResource TertiaryTextBrush}"
					   FontSize="12"
					   Margin="0 8 0 -8"
					   Text=""/>

			<Border x:Name="CardMemoEditorPanel"
					Grid.RowSpan="5"
					Margin="-22"
					Background="#66000000"
					Visibility="Collapsed"
					Panel.ZIndex="29">
				<Border Width="420"
						Padding="18"
						CornerRadius="12"
						Background="{DynamicResource InputDropDownBackgroundBrush}"
						HorizontalAlignment="Center"
						VerticalAlignment="Center">
					<StackPanel>
						<TextBlock x:Name="CardMemoEditorTitle"
								   Foreground="{DynamicResource PrimaryTextBrush}"
								   FontSize="16"
								   FontWeight="SemiBold"
								   Margin="0 0 0 10"/>
						<TextBox x:Name="CardMemoEditorBox"
								 AcceptsReturn="True"
								 TextWrapping="Wrap"
								 VerticalContentAlignment="Top"
								 Padding="8 6"
								 MaxLength="500"
								 MinHeight="100"
								 VerticalScrollBarVisibility="Auto"/>
						<StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 12 0 0">
							<Button Content="취소" Width="70" Height="30" Margin="0 0 8 0" Click="CancelCardMemo_Click"/>
							<Button Content="저장" Width="70" Height="30" Click="SaveCardMemo_Click"/>
						</StackPanel>
					</StackPanel>
				</Border>
			</Border>

			<Border x:Name="LoadingOverlay"
					Grid.RowSpan="5"
					Margin="-22"
					Background="{DynamicResource InputDropDownBackgroundBrush}"
					Opacity="0"
					Visibility="Collapsed"
					Panel.ZIndex="35">
				<Grid>
					<StackPanel HorizontalAlignment="Center"
								VerticalAlignment="Center">
						<Grid Width="42"
							  Height="42"
							  HorizontalAlignment="Center"
							  RenderTransformOrigin="0.5,0.5">
							<Grid.RenderTransform>
								<RotateTransform x:Name="LoadingSpinnerRotation"/>
							</Grid.RenderTransform>
							<Ellipse Width="34"
									 Height="34"
									 Stroke="{DynamicResource InputBorderBrush}"
									 StrokeThickness="4"
									 Opacity="0.45"/>
							<Ellipse Width="34"
									 Height="34"
									 Stroke="{DynamicResource PrimaryTextBrush}"
									 StrokeThickness="4"
									 StrokeDashArray="1.8 4.2"
									 StrokeStartLineCap="Round"
									 StrokeEndLineCap="Round"/>
						</Grid>
						<TextBlock x:Name="LoadingOverlayText"
								   Text=""
								   Foreground="{DynamicResource PrimaryTextBrush}"
								   FontSize="13"
								   FontWeight="SemiBold"
								   Margin="0 12 0 0"
								   HorizontalAlignment="Center"/>
					</StackPanel>
				</Grid>
			</Border>

			<Canvas x:Name="DragOverlay"
					Grid.RowSpan="4"
					IsHitTestVisible="False"
					Panel.ZIndex="40">
				<Canvas x:Name="DropIndicatorClipHost"
						IsHitTestVisible="False"
						Visibility="Collapsed">
					<Border x:Name="DropInsertIndicator"
							Width="4"
							Height="120"
							Opacity="0"
							Background="{DynamicResource InputFocusedBorderBrush}"
							CornerRadius="2"/>
				</Canvas>
			</Canvas>

			<Border x:Name="DeleteDropZone"
					Grid.RowSpan="5"
					Height="156"
					Margin="-22 0 -22 -22"
					VerticalAlignment="Bottom"
					Visibility="Collapsed"
					Opacity="0"
					AllowDrop="True"
					DragEnter="DeleteDropZone_DragEnter"
					DragOver="DeleteDropZone_DragOver"
					DragLeave="DeleteDropZone_DragLeave"
					Drop="DeleteDropZone_Drop"
					Panel.ZIndex="30">
				<Border.Background>
					<LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
						<GradientStop Color="#00E53935" Offset="0"/>
						<GradientStop Color="#88E53935" Offset="0.46"/>
						<GradientStop Color="#DDE53935" Offset="1"/>
					</LinearGradientBrush>
				</Border.Background>
				<Grid>
					<TextBlock Text="삭제"
							   HorizontalAlignment="Center"
							   VerticalAlignment="Center"
							   Foreground="White"
							   FontSize="22"
							   FontWeight="Bold"/>
				</Grid>
			</Border>
		</Grid>
	</Border>
</Window>
